#!/bin/sh
# Moi commit: backup Odoo DB de may khac pull duoc cung data.
cd "$(git rev-parse --show-toplevel)" || exit 0
if [ -f "backup-database.bat" ] && [ -f "pgdata/PG_VERSION" ]; then
  echo "[LiteERP] pre-commit: backup database seed..."
  cmd //c backup-database.bat
  git add database/seed/demo.dump 2>/dev/null || true
fi
